# TutorLoop local environment
APP_ENV=development
CORS_ORIGINS=*
DEMO_SEED_ON_STARTUP=true

# MongoDB Atlas
# Leave blank for in-memory hackathon demo mode.
MONGODB_URI=
MONGODB_DB_NAME=tutorloop
# Each collection uses its own index (notes_vector_index, books_vector_index,
# book_chunks_vector_index, tutors_vector_index, ...). This is only a fallback
# name for collections not in that map. See scripts/create_vector_indexes.py.
MONGODB_VECTOR_INDEX=tutorloop_vector_index
MONGODB_TIMEOUT_MS=20000
MONGODB_ALLOW_VECTOR_FALLBACK=false
EMBEDDING_DIMENSIONS=768

# Gemini
# Leave blank for mock AI tutor, summary, reflection, quiz, and embedding behavior.
GEMINI_API_KEY=
# Text tutor chat / reflections (standard generateContent). Flash is fine here.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Realtime VOICE agent (Live API / bidiGenerateContent). Must be a "live" model.
# Use a native-audio Live model so the tutor can speak first and deliver a lecture.
# NOTE: gemini-3.1-flash-live-preview canNOT speak first (generate_reply ignored),
# and plain gemini-3.5-flash is NOT a Live model at all.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# LiveKit
# Leave blank for mock classroom tokens.
LIVEKIT_URL=wss://tutor-loop-azg1f8zh.livekit.cloud
LIVEKIT_API_KEY=API4EtJNYHbYm6U
LIVEKIT_API_SECRET=MX31JyP1zhdfuhcv91fZtEAXsf9mELJ2VrwwB94zp3dB

# LiveKit AI lecture agent (started automatically by run.py)
RUN_LIVEKIT_AGENT=true

# Demo auth only. Replace before production.
JWT_SECRET=change-this-before-production
